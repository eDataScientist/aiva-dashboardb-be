# Required runtime configuration
# Docker: use postgres_app:5432 for container-to-container networking (see docs/DOCKER_DB_CONNECTIVITY_NOTE.md)
# Local: use localhost:5433 if port-forwarding from the host
DATABASE_URL=postgresql+psycopg2://arabia_insurance:change_me@postgres_app:5432/aiva
AUTH_JWT_SECRET=replace_with_a_minimum_32_character_secret
AUTH_JWT_ALGORITHM=HS256
AUTH_ACCESS_TOKEN_EXPIRE_MINUTES=60
GRADING_PROVIDER=mock
GRADING_MODEL=mock-grade-v1
GRADING_REQUEST_TIMEOUT_SECONDS=30
GRADING_MAX_RETRIES=2
GRADING_PROMPT_VERSION=v1
GRADING_PROMPT_ASSETS_ROOT=
GRADING_API_KEY=
GRADING_BASE_URL=
GRADING_BATCH_SCHEDULER_ENABLED=false
GRADING_BATCH_SCHEDULER_HOUR_GST=1
GRADING_BATCH_MAX_BACKFILL_DAYS=31
GRADING_BATCH_STALE_RUN_TIMEOUT_MINUTES=180
GRADING_BATCH_ALLOW_MOCK_PROVIDER_RUNS=false
GRADING_METRICS_DEFAULT_WINDOW_DAYS=30
GRADING_METRICS_MAX_WINDOW_DAYS=366
DASHBOARD_DEFAULT_WINDOW_DAYS=7
DASHBOARD_MAX_WINDOW_DAYS=31
DASHBOARD_DEFAULT_WORST_PERFORMERS_LIMIT=10
DASHBOARD_MAX_WORST_PERFORMERS_LIMIT=50
MONITORING_DEFAULT_WINDOW_DAYS=1
MONITORING_MAX_WINDOW_DAYS=31
MONITORING_DEFAULT_PAGE_SIZE=50
MONITORING_MAX_PAGE_SIZE=200
MONITORING_DEFAULT_RECENT_HISTORY_LIMIT=30

# Optional metadata
APP_NAME=AIVA Dashboard Backend
APP_VERSION=0.1.0

# Optional JWT claims
AUTH_JWT_ISSUER=
AUTH_JWT_AUDIENCE=

# CORS (comma-separated origins, empty disables CORS)
CORS_ALLOWED_ORIGINS=
